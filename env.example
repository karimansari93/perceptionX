# Supabase Configuration
# Replace with your actual Supabase project URL and anon key from your Supabase dashboard
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Proxy Configuration (for development with ngrok)
# Uncomment and update these when using the proxy server
# VITE_SUPABASE_URL=https://your-ngrok-url.ngrok.io
# VITE_USE_PROXY=true

# Environment
NODE_ENV=development

# Report Server (PDF generation)
VITE_REPORT_SERVER_URL=https://your-report-server.railway.app
VITE_REPORT_API_KEY=your-report-api-key

# Optional: Error Tracking Service (Sentry, LogRocket, etc.)
VITE_SENTRY_DSN=your-sentry-dsn